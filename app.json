{
  "expo": {
    "name": "SafeRoute",
    "slug": "SafeRoute",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "saferoute",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anonymous.SafeRoute"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "googleDirectionsApiKey": "YOUR_GOOGLE_DIRECTIONS_API_KEY",
      "googlePlacesApiKey": "YOUR_GOOGLE_PLACES_API_KEY",
      "twilioAccountSid": "YOUR_TWILIO_ACCOUNT_SID",
      "twilioAuthToken": "YOUR_TWILIO_AUTH_TOKEN",
      "twilioWhatsAppNumber": "whatsapp:+14155238886",
      "router": {},
      "eas": {
        "projectId": "5b1d7d55-8889-4449-a213-ec9769ddf7ed"
      }
    }
  }
}
